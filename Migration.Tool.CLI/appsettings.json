{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System": "Warning",
      "Microsoft": "Warning",
      "Migration.Tool": "Trace",
      "Kentico.Xperience.UMT": "Warning"
    },
    // Full log (Trace + above สำหรับ Migration.Tool) — เหมือนเดิม ใช้ดู full detail
    "File": {
      "LogLevel": {
        "Default": "Warning",
        "System": "Warning",
        "Microsoft": "Warning",
        "Migration.Tool": "Trace",
        "Kentico.Xperience.UMT": "Warning"
      },
      "pathFormat": "logs/migration.tool.log",
      "OutputTemplate": "{Timestamp:o} ({SourceContext}) [{Level:u3}] {Message} ({EventId:x8}){NewLine}{Exception}"
    },
    // Warning log (Warning + Error) — ดู warning/error ที่ต้องสนใจ
    "FileWarning": {
      "LogLevel": {
        "Default": "Warning",
        "System": "Warning",
        "Microsoft": "Warning",
        "Migration.Tool": "Warning",
        "Kentico.Xperience.UMT": "Warning"
      },
      "pathFormat": "logs/migration.tool-warning.log",
      "OutputTemplate": "{Timestamp:o} ({SourceContext}) [{Level:u3}] {Message} ({EventId:x8}){NewLine}{Exception}"
    },
    // Error log (Error เท่านั้น) — ดู error ที่ migration ล้มเหลวชัดๆ
    "FileError": {
      "LogLevel": {
        "Default": "Error",
        "System": "Error",
        "Microsoft": "Error",
        "Migration.Tool": "Error",
        "Kentico.Xperience.UMT": "Error"
      },
      "pathFormat": "logs/migration.tool-error.log",
      "OutputTemplate": "{Timestamp:o} ({SourceContext}) [{Level:u3}] {Message} ({EventId:x8}){NewLine}{Exception}"
    }
  },
